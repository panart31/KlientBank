<Window x:Class="KlientBank.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="PanBank" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <Window.Resources>
        <!-- Blue/Yellow (Panart) palette -->
        <SolidColorBrush x:Key="AccentBrush" Color="#19D3FF"/>
        <SolidColorBrush x:Key="AccentBrushDark" Color="#0AAAD4"/>
        <SolidColorBrush x:Key="TextBrush" Color="#EAF2FF"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#9BB0C8"/>
        <SolidColorBrush x:Key="CardBrush" Color="#0B1220"/>
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#1B2B45"/>
        <SolidColorBrush x:Key="BgBrush" Color="#F4F7FB"/>
        <SolidColorBrush x:Key="OutputBgBrush" Color="#0A1222"/>
        <SolidColorBrush x:Key="OutputTextBrush" Color="#EAF2FF"/>
        <SolidColorBrush x:Key="SoftAccentBrush" Color="#FFCC00"/>

        <Style x:Key="RoundedButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Background" Value="{StaticResource CardBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="scale" ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="scale"
                                                             Storyboard.TargetProperty="ScaleX"
                                                             To="1.03"
                                                             Duration="0:0:0.12"/>
                                            <DoubleAnimation Storyboard.TargetName="scale"
                                                             Storyboard.TargetProperty="ScaleY"
                                                             To="1.03"
                                                             Duration="0:0:0.12"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Setter TargetName="border" Property="Background" Value="{StaticResource AccentBrushDark}"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="False">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="scale"
                                                             Storyboard.TargetProperty="ScaleX"
                                                             To="1"
                                                             Duration="0:0:0.08"/>
                                            <DoubleAnimation Storyboard.TargetName="scale"
                                                             Storyboard.TargetProperty="ScaleY"
                                                             To="1"
                                                             Duration="0:0:0.08"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Setter TargetName="border" Property="Background" Value="{StaticResource CardBrush}"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="scale"
                                                             Storyboard.TargetProperty="ScaleX"
                                                             To="0.98"
                                                             Duration="0:0:0.05"/>
                                            <DoubleAnimation Storyboard.TargetName="scale"
                                                             Storyboard.TargetProperty="ScaleY"
                                                             To="0.98"
                                                             Duration="0:0:0.05"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.55"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource CardBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="0"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Scrollbar styling (for TextBox / ScrollViewer) -->
        <Style x:Key="ScrollThumbStyle" TargetType="Thumb">
            <Setter Property="Width" Value="8"/>
            <Setter Property="MinHeight" Value="26"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="thumbBorder"
                                CornerRadius="6"
                                Background="{StaticResource AccentBrush}"
                                Opacity="0.55">
                            <Border.Effect>
                                <DropShadowEffect Color="#19D3FF"
                                                  BlurRadius="16"
                                                  ShadowDepth="0"
                                                  Opacity="0.18"/>
                            </Border.Effect>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="thumbBorder" Property="Opacity" Value="0.95"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="thumbBorder" Property="Opacity" Value="1"/>
                                <Setter TargetName="thumbBorder" Property="Background" Value="{StaticResource AccentBrushDark}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="10"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Opacity" Value="0.9"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track"
                                   IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.LineDownCommand"
                                                  Opacity="0"
                                                  Style="{x:Null}"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.LineUpCommand"
                                                  Opacity="0"
                                                  Style="{x:Null}"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ScrollThumbStyle}"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="1"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OutputTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource OutputTextBrush}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="12">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OutputGridHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#162742"/>
            <Setter Property="Foreground" Value="#EAF2FF"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="10,6"/>
        </Style>

        <Style x:Key="OutputGridCellStyle" TargetType="DataGridCell">
            <Setter Property="Foreground" Value="#EAF2FF"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#243044"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#F4F7FB" Offset="0"/>
                <GradientStop Color="#FFFFFF" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- subtle glow (reduced, to avoid "нечёткость") -->
        <Ellipse Width="520" Height="520"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Top"
                 Margin="0,60,0,0"
                 Fill="{StaticResource AccentBrush}"
                 Opacity="0.05"
                 IsHitTestVisible="False"/>

        <!-- Loading overlay (toggles from code-behind) -->
        <Grid x:Name="LoadingOverlay"
              Visibility="Collapsed"
              Background="#33000000"
              Opacity="1"
              Grid.ZIndex="50">
            <Border CornerRadius="18"
                    Background="#0B1220"
                    BorderBrush="#243044"
                    BorderThickness="1"
                    Padding="18"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="360">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="Обработка…"
                               Foreground="{StaticResource TextBrush}"
                               FontSize="14"
                               FontWeight="800"
                               Margin="0,0,0,12"
                               HorizontalAlignment="Center"/>
                    <ProgressBar IsIndeterminate="True"
                                 Height="6"
                                 Width="260"
                                 Foreground="{StaticResource AccentBrush}"
                                 Background="#243044"
                                 BorderThickness="0"
                                 />
                    <TextBlock Text="Не закрывай окно"
                               Foreground="{StaticResource MutedBrush}"
                               FontSize="12"
                               Margin="0,10,0,0"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>

        <Border x:Name="SuccessToast"
                Visibility="Collapsed"
                Grid.ZIndex="60"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,16,16,0"
                CornerRadius="12"
                Background="#0E1F37"
                BorderBrush="#1B365E"
                BorderThickness="1"
                Padding="14,10"
                Opacity="0"
                IsHitTestVisible="False">
            <Border.Effect>
                <DropShadowEffect Color="#19D3FF" BlurRadius="18" ShadowDepth="0" Opacity="0.25"/>
            </Border.Effect>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="✓" Foreground="{StaticResource AccentBrush}" FontSize="16" FontWeight="Bold" Margin="0,0,8,0"/>
                <TextBlock Text="Подключено" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold"/>
            </StackPanel>
        </Border>

        <Grid Margin="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Grid.ColumnSpan="2"
                    CornerRadius="18"
                    Background="{StaticResource CardBrush}"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="1"
                    Padding="18"
                    Margin="0,0,0,14">
                <Border.Effect>
                    <DropShadowEffect Color="#1A9FD3"
                                      BlurRadius="22"
                                      ShadowDepth="0"
                                      Opacity="0.30"/>
                </Border.Effect>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- PanartikBank logo (monogram) -->
                    <Border Width="46" Height="46" CornerRadius="16"
                            Background="{StaticResource AccentBrush}"
                            BorderBrush="#FFF2B3"
                            BorderThickness="2"
                            HorizontalAlignment="Left">
                        <Grid>
                            <!-- soft shadow layer -->
                            <TextBlock Text="PB"
                                       Foreground="#000000"
                                       Opacity="0.22"
                                       FontWeight="900"
                                       FontSize="18"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Margin="1,1,0,0"/>
                            <TextBlock Text="PB"
                                       Foreground="#0A0A0A"
                                       FontWeight="900"
                                       FontSize="18"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    <StackPanel Margin="14,0,0,0">
                        <TextBlock Text="PanBank" Foreground="{StaticResource TextBrush}"
                                   FontSize="18" FontWeight="900"/>
                        <TextBlock Text="Мобильный кабинет"
                                   Foreground="{StaticResource TextBrush}"
                                   FontSize="16"
                                   FontWeight="700"/>
                        <TextBlock Text="PanBank - Уверенность в каждом платеже"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="13"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Left panel -->
            <Border Grid.Row="1" Grid.Column="0"
                    CornerRadius="18"
                    Background="{StaticResource CardBrush}"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="1"
                    Padding="16">
                <Border.Effect>
                    <DropShadowEffect Color="#19D3FF"
                                      BlurRadius="26"
                                      ShadowDepth="0"
                                      Opacity="0.22"/>
                </Border.Effect>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Подключение"
                                   FontWeight="700"
                                   FontSize="14"
                                   Foreground="{StaticResource TextBrush}"
                                   Margin="0,0,0,10"/>

                        <StackPanel Margin="0,0,0,14">
                            <TextBlock Text="Сервер" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,0,0,6"/>
                            <TextBox x:Name="IpTextBox" Style="{StaticResource InputTextBoxStyle}" Text="192.168.77.249"/>

                            <TextBlock Text="Порт" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,12,0,6"/>
                            <TextBox x:Name="PortTextBox" Style="{StaticResource InputTextBoxStyle}" Text="44909"/>

                            <Button x:Name="ConnectButton"
                                    Style="{StaticResource RoundedButtonStyle}"
                                    Content="Подключить  →"
                                    Click="ConnectButton_Click"
                                    Margin="0,14,0,0"/>
                        </StackPanel>

                        <TextBlock Text="Операции" FontWeight="700" FontSize="14"
                                   Foreground="{StaticResource TextBrush}" Margin="0,0,0,10"/>

                        <StackPanel>
                            <Button x:Name="AllClientsButton" Style="{StaticResource RoundedButtonStyle}"
                                    Content="Все клиенты  ›" Click="AllClientsButton_Click" Margin="0,0,0,10"/>

                            <Button x:Name="AccountsButton" Style="{StaticResource RoundedButtonStyle}"
                                    Content="Счета  ›" Click="AccountsButton_Click" Margin="0,0,0,10"/>

                            <Button x:Name="CardsButton" Style="{StaticResource RoundedButtonStyle}"
                                    Content="Карты  ›" Click="CardsButton_Click" Margin="0,0,0,10"/>

                            <Button x:Name="TransactionsButton" Style="{StaticResource RoundedButtonStyle}"
                                    Content="История  ›" Click="TransactionsButton_Click" Margin="0,0,0,10"/>

                            <Button x:Name="FindClientButton" Style="{StaticResource RoundedButtonStyle}"
                                    Content="Найти клиента  ›" Click="FindClientButton_Click"/>
                        </StackPanel>

                        <Separator Margin="16,14"/>

                        <TextBlock Text="Параметры поиска" FontWeight="700" FontSize="14"
                                   Foreground="{StaticResource TextBrush}" Margin="0,0,0,10"/>

                        <StackPanel>
                            <TextBlock Text="ID клиента" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,0,0,6"/>
                            <TextBox x:Name="IdTextBox" Style="{StaticResource InputTextBoxStyle}"/>

                            <TextBlock Text="Телефон" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,12,0,6"/>
                            <TextBox x:Name="PhoneTextBox" Style="{StaticResource InputTextBoxStyle}"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Output panel -->
            <Border Grid.Row="1" Grid.Column="1"
                    CornerRadius="18"
                    Background="{StaticResource CardBrush}"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="1"
                    Margin="14,0,0,0"
                    Padding="16">
                <Border.Effect>
                    <DropShadowEffect Color="#19D3FF"
                                      BlurRadius="18"
                                      ShadowDepth="0"
                                      Opacity="0.18"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,10">
                        <Border Height="10" Width="10"
                                Background="{StaticResource AccentBrush}"
                                CornerRadius="5"
                                VerticalAlignment="Center"
                                Margin="0,0,10,0"/>
                        <TextBlock Text="Результат"
                                   FontWeight="900"
                                   FontSize="14"
                                   Foreground="{StaticResource TextBrush}"/>
                        <TextBlock Text=" (данные)"
                                   FontWeight="600"
                                   FontSize="13"
                                   Foreground="{StaticResource MutedBrush}"
                                   Margin="6,0,0,0"/>
                    </StackPanel>

                    <TextBox x:Name="OutputTextBox"
                             Grid.Row="1"
                             Style="{StaticResource OutputTextBoxStyle}"/>

                    <DataGrid x:Name="OutputDataGrid"
                              Grid.Row="1"
                              AutoGenerateColumns="True"
                              Visibility="Collapsed"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              RowBackground="#0C162B"
                              AlternatingRowBackground="#101D36"
                              Background="#0A1222"
                              Foreground="#EAF2FF"
                              BorderBrush="{StaticResource BorderBrushSoft}"
                              BorderThickness="1"
                              IsReadOnly="True"
                              CanUserSortColumns="True"
                              CanUserReorderColumns="False"
                              CanUserResizeRows="False"
                              ColumnHeaderHeight="34"
                              RowHeight="30"
                              HorizontalGridLinesBrush="#243044"
                              VerticalGridLinesBrush="#243044"
                              CellStyle="{StaticResource OutputGridCellStyle}"
                              ColumnHeaderStyle="{StaticResource OutputGridHeaderStyle}"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
